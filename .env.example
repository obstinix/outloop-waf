# OUTERLOOP WAF — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://outerloop-waf.vercel.app,http://localhost:3000

# Admin API key — used to authenticate /api/admin/* endpoints (Phase 2)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WAF_ADMIN_KEY=

# Upstash Redis URL — for persistent IP blocklist and counters (Phase 2)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Environment tag
ENVIRONMENT=development
