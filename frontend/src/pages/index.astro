---
import Layout from '../layouts/Layout.astro';
import GravityStatus from '../components/GravityStatus.jsx';
---

<Layout title="Web Application Firewall">
  <main>
    <section class="hero">
      <div class="hero-content">
        <div class="status-badge">
          <span class="status-dot"></span>
          <span>System Operational</span>
        </div>
        <h1>Web Application Firewall</h1>
        <p class="subtitle">
          Production-grade security middleware with real-time threat detection 
          and request inspection capabilities.
        </p>
        <div class="hero-actions">
          <a href="/api/docs" class="btn btn-primary">API Documentation</a>
          <a href="#features" class="btn btn-secondary">Learn More</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="shield-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L3 7V12C3 17.5 7.5 22 12 22C16.5 22 21 17.5 21 12V7L12 2Z" 
                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 12L11 14L15 10" 
                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </section>

    <section id="features" class="features">
      <h2>Security Features</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M12 15V17M6 21H18C19.1046 21 20 20.1046 20 19V5C20 3.89543 19.1046 3 18 3H6C4.89543 3 4 3.89543 4 5V19C4 20.1046 4.89543 21 6 21Z" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>SQL Injection Protection</h3>
          <p>Advanced pattern matching to detect and block SQL injection attempts before they reach your database.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M10 14L12 12M12 12L14 10M12 12L10 10M12 12L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>XSS Prevention</h3>
          <p>Comprehensive cross-site scripting detection with multiple encoding passes and event handler inspection.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M3 12H21M3 6H21M3 18H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Header Validation</h3>
          <p>Request header inspection for CRLF injection, overflow attacks, and malformed content types.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M4 4L20 20M12 12V4M12 12L18 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Path Traversal Detection</h3>
          <p>Multi-layer decoding to catch obfuscated directory traversal and file inclusion attempts.</p>
        </div>
      </div>
    </section>

    <section class="system-status">
      <h2>System Status</h2>
      <div class="status-container">
        <GravityStatus client:load />
      </div>
    </section>

    <section class="architecture">
      <h2>Architecture</h2>
      <div class="architecture-diagram">
        <div class="arch-flow">
          <div class="arch-node request">
            <span>Request</span>
          </div>
          <div class="arch-arrow">→</div>
          <div class="arch-node waf">
            <span>WAF Middleware</span>
          </div>
          <div class="arch-arrow">→</div>
          <div class="arch-node engine">
            <span>Analysis Engine</span>
          </div>
          <div class="arch-arrow">→</div>
          <div class="arch-node decision">
            <span>Allow / Block</span>
          </div>
        </div>
      </div>
      <div class="arch-details">
        <p>
          Requests pass through the WAF middleware where they are decoded, 
          normalized, and analyzed against our security rule set. Threats are 
          blocked before reaching application logic, with detailed logging 
          and request tracking for security auditing.
        </p>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-content">
      <p>&copy; 2024 Web Application Firewall</p>
      <nav>
        <a href="/api/health">Health</a>
        <a href="/api/docs">API Docs</a>
        <a href="https://github.com/obstinix/Web-Application-Firewall-WAF-">GitHub</a>
      </nav>
    </div>
  </footer>
</Layout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding: 4rem 0;
    min-height: 70vh;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 2rem;
    font-size: 0.875rem;
    color: #22c55e;
    margin-bottom: 1.5rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  h1 {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #fff 0%, #a0aec0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.25rem;
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.05);
    color: #e2e8f0;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .shield-icon {
    width: 200px;
    height: 200px;
    color: #3b82f6;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }

  .features {
    padding: 6rem 0;
  }

  h2 {
    font-size: 2rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 3rem;
    color: #f1f5f9;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 1rem;
    padding: 2rem;
    transition: all 0.3s;
  }

  .feature-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(59, 130, 246, 0.3);
    transform: translateY(-4px);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    color: #3b82f6;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-bottom: 0.75rem;
  }

  .feature-card p {
    font-size: 0.9375rem;
    color: #94a3b8;
    line-height: 1.6;
  }

  .system-status {
    padding: 4rem 0;
  }

  .status-container {
    max-width: 400px;
    margin: 0 auto;
  }

  .architecture {
    padding: 4rem 0;
  }

  .architecture-diagram {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 1rem;
    padding: 3rem;
    margin-bottom: 2rem;
  }

  .arch-flow {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .arch-node {
    padding: 1rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 500;
  }

  .arch-node.request {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #22c55e;
  }

  .arch-node.waf {
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.3);
    color: #3b82f6;
  }

  .arch-node.engine {
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.3);
    color: #a855f7;
  }

  .arch-node.decision {
    background: rgba(249, 115, 22, 0.1);
    border: 1px solid rgba(249, 115, 22, 0.3);
    color: #f97316;
  }

  .arch-arrow {
    color: #475569;
    font-size: 1.5rem;
  }

  .arch-details p {
    text-align: center;
    color: #94a3b8;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  footer {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2rem;
    margin-top: 4rem;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #64748b;
    font-size: 0.875rem;
  }

  footer nav {
    display: flex;
    gap: 2rem;
  }

  footer a {
    color: #64748b;
    text-decoration: none;
    transition: color 0.2s;
  }

  footer a:hover {
    color: #e2e8f0;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }

    h1 {
      font-size: 2.5rem;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .shield-icon {
      width: 120px;
      height: 120px;
    }

    .arch-flow {
      flex-direction: column;
    }

    .arch-arrow {
      transform: rotate(90deg);
    }

    .footer-content {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
